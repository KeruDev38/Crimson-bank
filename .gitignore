# Crimson NeoBank Root .gitignore

# Environment files
.env
.env.local
.env.production

# IDE files
.vscode/
.idea/
*.swp
*.swo

# OS files
.DS_Store
Thumbs.db

# Logs
*.log
logs/

# Temporary files
tmp/
temp/

# Docker volumes (if not using named volumes)
data/

# Build artifacts
dist/
build/
target/

# Node modules (if any at root)
node_modules/

# Backup files
*.bak
*.backup