# Crimson NeoBank API Environment Variables

# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=crimson_bank
DB_USERNAME=crimson_user
DB_PASSWORD=crimson_password

# JWT Configuration
JWT_SECRET=changeMeToASecretKeyThatIsAtLeast32CharactersLong
JWT_EXPIRATION=86400000

# Internal Service Communication
INTERNAL_SERVICE_TOKEN=changeMeToAServiceTokenThatIsAtLeast32CharactersLong

# External Service URLs
ACCOUNT_SERVICE_URL=http://localhost:8082

# Server Configuration
SERVER_PORT=8080

# Logging
LOG_LEVEL=INFO

# Database Connection Pool
DB_MAX_CONNECTIONS=10
DB_MIN_CONNECTIONS=2
